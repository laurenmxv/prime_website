# Prime Outdoor Experts — Environment Variables
# Copy this file to `.env` for local development. NEVER commit .env to git.
# In Vercel: add each var in Project Settings → Environment Variables.

# ---- Form backend (Vercel Function + Resend) ----
# Resend API key — sign up at https://resend.com (free 3k emails/mo)
# Used by /api/quote.js to send form submissions to the owner inbox.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where to deliver form submissions
QUOTE_TO_EMAIL=info@primeoutdoorexperts.com

# Verified sender domain in Resend (must match a domain you control)
QUOTE_FROM_EMAIL=quotes@primeoutdoorexperts.com

# Optional: hCaptcha for bot protection
# HCAPTCHA_SECRET=
# HCAPTCHA_SITEKEY=

# ---- Google Places API (for live reviews) ----
# Restrict the key to: HTTP referrers (primeoutdoorexperts.com/*) + Places API only.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=ChIJlY-Igl4N54gRwKBx4CPgMOA
